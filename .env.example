# =============================================
# ALPACA API CREDENTIALS — PAPER TRADING
# =============================================
# Copia este archivo como ".env" y rellena tus valores reales.
# NUNCA compartas ni subas el archivo .env a un repositorio.

# Keys del entorno Paper Trading (https://app.alpaca.markets/paper-trading)
ALPACA_API_KEY=TU_API_KEY_AQUI
ALPACA_SECRET_KEY=TU_SECRET_KEY_AQUI

# Modo de operación: "paper" o "live"
# Mantén en "paper" durante desarrollo y pruebas
ALPACA_MODE=paper

# =============================================
# ANTHROPIC API KEY — Módulo 5 (Sentimiento)
# =============================================
# Obtén tu key en: https://console.anthropic.com
# Si no la configuras, el módulo de sentimiento se desactiva
# y el bot opera solo con análisis técnico (Módulo 3).
ANTHROPIC_API_KEY=
